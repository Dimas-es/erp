# Copy ke .env.local dan isi nilai sesuai environment Anda.
# cp .env.local.example .env.local

# Wajib. URI koneksi MongoDB (lokal atau Atlas).
MONGODB_URI=mongodb://localhost:27017/erp-toko-bangunan

# Wajib untuk NextAuth. Minimal ~32 karakter; jangan commit nilai asli ke git.
AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# URL publik aplikasi (development: localhost; production: domain Anda).
NEXTAUTH_URL=http://localhost:3000
